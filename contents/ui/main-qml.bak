import QtQuick 2.0
import org.kde.plasma.core 2.0 as PlasmaCore
import org.kde.plasma.plasmoid 2.0

Item {
    id: root

    // --- Default size: fit 744x1052 inside a 512x512 box, preserving aspect ---
    property int svgW: 744
    property int svgH: 1052
    property int fitBox: 384
    property real fitScale: Math.min(fitBox / svgW, fitBox / svgH)
    implicitWidth:  Math.round(svgW * fitScale)   // ≈ 362
    implicitHeight: Math.round(svgH * fitScale)   // = 512

    Plasmoid.backgroundHints: PlasmaCore.Types.NoBackground

    // ===== Load the split SVGs once =====
    PlasmaCore.Svg { id: bottomArt; imagePath: Qt.resolvedUrl("../images/fatcat-bottom.svg").toString() }
    PlasmaCore.Svg { id: bodyArt;   imagePath: Qt.resolvedUrl("../images/fatcat-body.svg").toString() }
    PlasmaCore.Svg { id: topOpen;   imagePath: Qt.resolvedUrl("../images/fatcat-top-eyes-open.svg").toString() }
    PlasmaCore.Svg { id: topClosed; imagePath: Qt.resolvedUrl("../images/fatcat-top-eyes-closed.svg").toString() }

    // ===== Base (everything under the body) =====
    PlasmaCore.SvgItem {
        anchors.fill: parent
        svg: bottomArt
    }

    // ===== Body (scaled horizontally to make him FAT) =====
    // Visual scale range
    property real minScale: 1.0          // scale at 0%
    property real maxScale: 2.0          // scale at "old 60%" (because of calibration mapping)
    // Where to grow from
    property bool growFromCenter: true   // false -> grow from left edge

    // Calibration: what *old* percent equals the new 100% (you liked old 60%)
    property int  calibrationPercent: 60

    // Manual debug: set a value 0..100 and ignore real RAM
    property bool manualOverride: false
    property int  manualPercent: 60

    // Live RAM fraction (0..1) when manual is off
    property real measuredRamFrac: 0.0

    // Input fraction 0..1 (manual or real), clamped
    property real rawFrac: manualOverride
                           ? Math.max(0, Math.min(100, manualPercent)) / 100.0
                           : Math.max(0, Math.min(1, measuredRamFrac))

    // Re-normalized fraction: map 0..100 new -> 0..calibrationPercent old (e.g., 100% => old 60%)
    property real effFrac: rawFrac * (Math.max(1, calibrationPercent) / 100.0)

    PlasmaCore.SvgItem {
        id: body
        anchors.fill: parent
        svg: bodyArt

        transform: Scale {
            origin.x: growFromCenter ? body.width / 2 : 0
            origin.y: body.height / 2
            xScale: root.minScale + root.effFrac * (root.maxScale - root.minScale)
            yScale: 1
        }
    }

    // ===== Top (blink between open/closed) =====
    // Idle blink timing (random each blink)
    property int idleBlinkMin: 1800    // ms
    property int idleBlinkMax: 15000   // ms
    property int closedBlinkMs: 140    // ms eyes-closed duration

    property bool eyesOpen: true

    PlasmaCore.SvgItem {
        anchors.fill: parent
        svg: eyesOpen ? topOpen : topClosed
    }

    Timer {
        id: blink
        repeat: true
        running: true
        interval: idleBlinkMin + Math.floor(Math.random() * (idleBlinkMax - idleBlinkMin + 1))
        onTriggered: {
            eyesOpen = !eyesOpen
            if (eyesOpen) {
                interval = idleBlinkMin + Math.floor(Math.random() * (idleBlinkMax - idleBlinkMin + 1))
            } else {
                interval = closedBlinkMs
            }
        }
    }

    // ---- Real RAM polling (ignored when manualOverride=true) ----
    function pollMem() {
        var xhr = new XMLHttpRequest();
        xhr.open("GET", "file:///proc/meminfo");
        xhr.onreadystatechange = function() {
            if (xhr.readyState !== XMLHttpRequest.DONE) return;
            var t = xhr.responseText || "";
            var mt = /MemTotal:\s+(\d+)\s+kB/.exec(t);
            var ma = /MemAvailable:\s+(\d+)\s+kB/.exec(t);
            if (!mt || !ma) return;
            var total = parseInt(mt[1]);
            var avail = parseInt(ma[1]);
            var used = Math.max(0, total - avail);
            measuredRamFrac = total > 0 ? (used / total) : 0;
        }
        xhr.send();
    }
    Timer {
        interval: 1000
        repeat: true
        running: !root.manualOverride
        onTriggered: pollMem()
        Component.onCompleted: { if (running) pollMem(); }
    }

    // ===== Debug overlay (hidden by default; press 'D' to toggle) =====
    property bool debugOverlay: false

    Rectangle {
        anchors.left: parent.left
        anchors.bottom: parent.bottom
        anchors.margins: 6
        color: "#44000000"
        radius: 4
        height: 26
        width: label.implicitWidth + 12
        visible: debugOverlay
        Text {
            id: label
            anchors.centerIn: parent
            color: "white"
            font.pixelSize: 14
            text: root.manualOverride
                  ? ("Manual: " + root.manualPercent + "%  (100%→old " + root.calibrationPercent + "%)  scale=" +
                     (root.minScale + root.effFrac * (root.maxScale - root.minScale)).toFixed(2))
                  : ("RAM: " + Math.round(root.measuredRamFrac * 100) + "%  (100%→old " + root.calibrationPercent + "%)")
        }
    }

    // Keyboard controls
    focus: true
    Keys.onPressed: {
        if (event.key === Qt.Key_D) { debugOverlay = !debugOverlay; event.accepted = true; return; }
        if (event.key === Qt.Key_M) { manualOverride = !manualOverride; event.accepted = true; return; }
        if (!manualOverride) return;
        if (event.key === Qt.Key_Right || event.key === Qt.Key_Up) {
            manualPercent = Math.min(100, manualPercent + 5); event.accepted = true;
        } else if (event.key === Qt.Key_Left || event.key === Qt.Key_Down) {
            manualPercent = Math.max(0, manualPercent - 5); event.accepted = true;
        }
    }
}
